root = true

[*]
indent_size = 2
indent_style = space

[*.cs]
indent_size = 2
indent_style = space
csharp_new_line_before_open_brace = none

dotnet_naming_style.camel_case_style.capitalization = camel_case
dotnet_naming_symbols.local_variables_symbols.applicable_kinds = local
dotnet_naming_rule.local_variables_rule.symbols = local_variables_symbols
dotnet_naming_rule.local_variables_rule.style = camel_case_style
dotnet_naming_rule.local_variables_rule.severity = error

csharp_style_var_for_built_in_types = false:error
csharp_style_var_when_type_is_apparent = false:error
csharp_style_var_elsewhere = false:error